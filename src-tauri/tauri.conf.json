{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "상권스카우트",
  "version": "0.1.0",
  "identifier": "com.kown.localbizscout",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "상권스카우트",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src https://apis.data.go.kr https://dapi.kakao.com; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxNjk3Qzk5OEI5MjczM0QKUldROWM1S0xtWHhwY1cwK3hsRld1allMOW5CV3dNM28yNTQrZ1lrYWdPTU9GTW10VGN0T2ZXdWgK",
      "endpoints": [
        "https://github.com/finalsoul1/localbiz-scout-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
